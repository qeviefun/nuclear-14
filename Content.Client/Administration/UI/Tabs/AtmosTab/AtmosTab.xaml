<!-- #Misfits Change — vertical list layout with inline descriptions -->
<Control
    xmlns="https://spacestation14.io"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cc="clr-namespace:Content.Client.Administration.UI.CustomControls"
    xmlns:at="clr-namespace:Content.Client.Administration.UI.Tabs.AtmosTab"
    Margin="4"
    MinSize="50 50">
    <ScrollContainer VerticalExpand="True">
        <BoxContainer Orientation="Vertical" SeparationOverride="4">
            <BoxContainer Orientation="Horizontal" SeparationOverride="8">
                <cc:UICommandButton Text="{Loc ui-tab-atmos-add-atmos}" Command="addatmos" WindowType="{x:Type at:AddAtmosWindow}" MinWidth="180" />
                <Label Text="{Loc misfits-atmos-tab-add-atmos-desc}" VerticalAlignment="Center" StyleClasses="LabelSubText" />
            </BoxContainer>
            <BoxContainer Orientation="Horizontal" SeparationOverride="8">
                <cc:UICommandButton Text="{Loc ui-tab-atmos-add-gas}" Command="addgas" WindowType="{x:Type at:AddGasWindow}" MinWidth="180" />
                <Label Text="{Loc misfits-atmos-tab-add-gas-desc}" VerticalAlignment="Center" StyleClasses="LabelSubText" />
            </BoxContainer>
            <BoxContainer Orientation="Horizontal" SeparationOverride="8">
                <cc:UICommandButton Text="{Loc ui-tab-atmos-fill-gas}" Command="fillgas" WindowType="{x:Type at:FillGasWindow}" MinWidth="180" />
                <Label Text="{Loc misfits-atmos-tab-fill-gas-desc}" VerticalAlignment="Center" StyleClasses="LabelSubText" />
            </BoxContainer>
            <BoxContainer Orientation="Horizontal" SeparationOverride="8">
                <cc:UICommandButton Text="{Loc ui-tab-atmos-set-temperature-title}" Command="settemp" WindowType="{x:Type at:SetTemperatureWindow}" MinWidth="180" />
                <Label Text="{Loc misfits-atmos-tab-set-temp-desc}" VerticalAlignment="Center" StyleClasses="LabelSubText" />
            </BoxContainer>
        </BoxContainer>
    </ScrollContainer>
</Control>
