<!-- #Misfits Change — vertical list layout with inline descriptions -->
<Control
    xmlns="https://spacestation14.io"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cc="clr-namespace:Content.Client.Administration.UI.CustomControls"
    xmlns:abt="clr-namespace:Content.Client.Administration.UI.Tabs.AdminbusTab"
    Margin="4"
    MinSize="50 50">
    <ScrollContainer VerticalExpand="True">
        <BoxContainer Orientation="Vertical" SeparationOverride="4">
            <BoxContainer Orientation="Horizontal" SeparationOverride="8">
                <Button Name="SpawnEntitiesButton" Text="{Loc 'sandbox-window-spawn-entities-button'}" MinWidth="180" />
                <Label Text="{Loc misfits-adminbus-tab-spawn-entities-desc}" VerticalAlignment="Center" StyleClasses="LabelSubText" />
            </BoxContainer>
            <BoxContainer Orientation="Horizontal" SeparationOverride="8">
                <Button Name="SpawnDungeonsButton" Text="{Loc 'sandbox-window-spawn-dungeons-button'}" MinWidth="180" />
                <Label Text="{Loc misfits-adminbus-tab-spawn-dungeons-desc}" VerticalAlignment="Center" StyleClasses="LabelSubText" />
            </BoxContainer>
            <BoxContainer Orientation="Horizontal" SeparationOverride="8">
                <Button Name="SpawnTilesButton" Text="{Loc 'sandbox-window-spawn-tiles-button'}" MinWidth="180" />
                <Label Text="{Loc misfits-adminbus-tab-spawn-tiles-desc}" VerticalAlignment="Center" StyleClasses="LabelSubText" />
            </BoxContainer>
            <BoxContainer Orientation="Horizontal" SeparationOverride="8">
                <Button Name="SpawnDecalsButton" Text="{Loc 'sandbox-window-spawn-decals-button'}" MinWidth="180" />
                <Label Text="{Loc misfits-adminbus-tab-spawn-decals-desc}" VerticalAlignment="Center" StyleClasses="LabelSubText" />
            </BoxContainer>
            <BoxContainer Orientation="Horizontal" SeparationOverride="8">
                <Button Name="LoadGamePrototypeButton" Text="{Loc 'load-game-prototype'}" MinWidth="180" />
                <Label Text="{Loc misfits-adminbus-tab-load-prototype-desc}" VerticalAlignment="Center" StyleClasses="LabelSubText" />
            </BoxContainer>
            <BoxContainer Orientation="Horizontal" SeparationOverride="8">
                <cc:UICommandButton Name="LoadBlueprintsButton" Command="loadbp" Text="{Loc 'load-blueprints'}" WindowType="{x:Type abt:LoadBlueprintsWindow}" MinWidth="180" />
                <Label Text="{Loc misfits-adminbus-tab-load-blueprints-desc}" VerticalAlignment="Center" StyleClasses="LabelSubText" />
            </BoxContainer>
            <BoxContainer Orientation="Horizontal" SeparationOverride="8">
                <cc:CommandButton Command="deleteewc Singularity" Name="DeleteSingulos" Text="{Loc 'delete-singularities'}" MinWidth="180" />
                <Label Text="{Loc misfits-adminbus-tab-delete-singulos-desc}" VerticalAlignment="Center" StyleClasses="LabelSubText" />
            </BoxContainer>
        </BoxContainer>
    </ScrollContainer>
</Control>
