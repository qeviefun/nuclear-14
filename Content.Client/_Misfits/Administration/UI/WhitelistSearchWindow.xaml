<!-- #Misfits Change - Whitelist Search admin panel XAML -->
<controls:FancyWindow
        xmlns="https://spacestation14.io"
        xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
    Title="Whitelist Search" MinSize="1100 720">
    <BoxContainer Orientation="Vertical" Margin="4">
        <!-- Search Area -->
        <BoxContainer Orientation="Horizontal" Margin="0 0 0 4">
            <Label Text="Search Player:" Margin="0 0 8 0" />
            <LineEdit Name="SearchBox" PlaceHolder="Type a player name (min 2 chars)..." HorizontalExpand="True" />
            <Button Name="SearchButton" Text="Search" Margin="4 0 0 0" MinWidth="80" />
        </BoxContainer>

        <!-- Search Results -->
        <BoxContainer Orientation="Vertical" Margin="0 0 0 4" VerticalExpand="False" MinSize="0 150" MaxHeight="200">
            <Label Text="Search Results:" Margin="0 0 0 2" />
            <ScrollContainer VerticalExpand="True" HorizontalExpand="True">
                <BoxContainer Name="SearchResults" Orientation="Vertical" HorizontalExpand="True" />
            </ScrollContainer>
        </BoxContainer>

        <!-- Selected Player Panel (greyed background for visual separation) -->
        <PanelContainer VerticalExpand="True" StyleClasses="BackgroundDark" Margin="0 2 0 0">
            <BoxContainer Orientation="Vertical" Margin="6">
                <!-- Player header -->
                <Label Name="SelectedPlayerLabel" Text="No player selected" Margin="0 2 0 2" StyleClasses="LabelHeadingBig" />
                <Label Name="SelectedStationLabel" Text="Station: none" Margin="0 0 0 4" StyleClasses="LabelSubText" />

                <!-- Role search filter -->
                <BoxContainer Orientation="Horizontal" Margin="0 0 0 6" SeparationOverride="6">
                    <Label Text="Search Role:" Margin="0 0 4 0" VerticalAlignment="Center" />
                    <LineEdit Name="RoleSearchBox" PlaceHolder="Filter roles by name..." HorizontalExpand="True" />
                </BoxContainer>

                <!-- Job Whitelists for Selected Player -->
                <ScrollContainer VerticalExpand="True">
                    <BoxContainer Name="Departments" Orientation="Vertical" />
                </ScrollContainer>
            </BoxContainer>
        </PanelContainer>
    </BoxContainer>
</controls:FancyWindow>
