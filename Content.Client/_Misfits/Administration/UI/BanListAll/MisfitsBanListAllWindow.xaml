<!-- #Misfits Add - Global ban list window: 4 tabs for active/all server bans and role bans -->
<controls:MisfitsBanListAllWindow
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client._Misfits.Administration.UI.BanListAll"
    xmlns:bans="clr-namespace:Content.Client._Misfits.Administration.UI.BanListAll.Bans"
    xmlns:roleBans="clr-namespace:Content.Client._Misfits.Administration.UI.BanListAll.RoleBans"
    SetSize="1600 500">
    <TabContainer Name="TabContainer">
        <bans:MisfitsBanListAllControl Name="ActiveBanList" Access="Public"/>
        <roleBans:MisfitsRoleBanListAllControl Name="ActiveRoleBanList" Access="Public"/>
        <bans:MisfitsBanListAllControl Name="AllBanList" Access="Public"/>
        <roleBans:MisfitsRoleBanListAllControl Name="AllRoleBanList" Access="Public"/>
    </TabContainer>
</controls:MisfitsBanListAllWindow>
