<!-- #Misfits Change - Whitelisting tab for admin menu, vertical list layout -->
<Control
    xmlns="https://spacestation14.io"
    xmlns:cc="clr-namespace:Content.Client.Administration.UI.CustomControls"
    Margin="4"
    MinSize="50 50">
    <ScrollContainer VerticalExpand="True">
        <BoxContainer Orientation="Vertical" SeparationOverride="4">
            <BoxContainer Orientation="Horizontal" SeparationOverride="8">
                <cc:CommandButton Command="whitelistsearch" Text="{Loc misfits-whitelisting-tab-role-whitelists-btn}" MinWidth="180" />
                <Label Text="{Loc misfits-whitelisting-tab-role-whitelists-desc}" VerticalAlignment="Center" StyleClasses="LabelSubText" />
            </BoxContainer>
            <BoxContainer Orientation="Horizontal" SeparationOverride="8">
                <cc:CommandButton Command="whitelistslots" Text="{Loc misfits-whitelisting-tab-job-slots-btn}" MinWidth="180" />
                <Label Text="{Loc misfits-whitelisting-tab-job-slots-desc}" VerticalAlignment="Center" StyleClasses="LabelSubText" />
            </BoxContainer>
        </BoxContainer>
    </ScrollContainer>
</Control>
