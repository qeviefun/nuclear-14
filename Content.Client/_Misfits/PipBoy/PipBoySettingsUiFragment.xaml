<!-- #Misfits Add - PipBoy Settings program UI (split from PipBoy Hub). -->
<pipboy:PipBoySettingsUiFragment
    xmlns="https://spacestation14.io"
    xmlns:pipboy="clr-namespace:Content.Client._Misfits.PipBoy"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
    Orientation="Vertical"
    HorizontalExpand="True"
    VerticalExpand="True"
    Margin="5">

    <!-- ═══════════ LOCK SCREEN ═══════════ -->
    <BoxContainer Name="LockScreen"
                  Orientation="Vertical"
                  HorizontalExpand="True"
                  VerticalExpand="True"
                  Visible="False"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
        <Label Text="{Loc pipboy-hub-locked-title}"
               StyleClasses="LabelHeading"
               HorizontalAlignment="Center"
               Margin="0 8" />
        <LineEdit Name="PasswordInput"
                  PlaceHolder="{Loc pipboy-hub-password-placeholder}"
                  MinWidth="200"
                  Margin="0 4" />
        <Button Name="UnlockButton"
                Text="{Loc pipboy-hub-unlock}"
                MinWidth="120"
                HorizontalAlignment="Center"
                Margin="0 4" />
        <Label Name="LockErrorLabel"
               Text=""
               StyleClasses="LabelDanger"
               HorizontalAlignment="Center"
               Visible="False" />
    </BoxContainer>

    <!-- ═══════════ MAIN SETTINGS ═══════════ -->
    <BoxContainer Name="MainPanel"
                  Orientation="Vertical"
                  HorizontalExpand="True"
                  VerticalExpand="True">

        <!-- Header -->
        <controls:StripeBack MinSize="48 48" VerticalExpand="False">
            <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
                <Label Text="{Loc pipboy-hub-tab-settings}"
                       StyleClasses="LabelHeading"
                       HorizontalExpand="True"
                       Margin="8 0"
                       VerticalAlignment="Center" />
                <Label Name="OwnNumberLabel"
                       Text="#0000"
                       StyleClasses="LabelSubText"
                       VerticalAlignment="Center"
                       Margin="0 0 8 0" />
            </BoxContainer>
        </controls:StripeBack>

        <PanelContainer StyleClasses="AngleRect" HorizontalExpand="True" Margin="0 2">
            <BoxContainer Orientation="Vertical" Margin="8">
                <!-- Visibility toggle -->
                <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0 4">
                    <Label Text="{Loc pipboy-hub-settings-visibility}"
                           HorizontalExpand="True"
                           VerticalAlignment="Center" />
                    <Button Name="VisibilityToggleBtn"
                            Text="{Loc pipboy-hub-visible}"
                            MinWidth="80" />
                </BoxContainer>

                <!-- Status section -->
                <Label Text="{Loc pipboy-hub-settings-status}"
                       StyleClasses="LabelHeading"
                       Margin="0 8 0 4" />
                <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0 2">
                    <OptionButton Name="StatusDropdown"
                                  HorizontalExpand="False"
                                  MinWidth="120" />
                    <LineEdit Name="StatusMessageInput"
                              PlaceHolder="{Loc pipboy-hub-status-message-placeholder}"
                              HorizontalExpand="True"
                              Margin="4 0 0 0"
                              StyleClasses="OpenRight" />
                    <Button Name="SetStatusBtn"
                            Text="{Loc pipboy-hub-set-status}"
                            MinWidth="60"
                            StyleClasses="OpenLeft" />
                </BoxContainer>
                <Label Name="CurrentStatusLabel"
                       Text=""
                       StyleClasses="LabelSubText"
                       Margin="0 2" />

                <!-- Password section -->
                <Label Text="{Loc pipboy-hub-settings-password}"
                       StyleClasses="LabelHeading"
                       Margin="0 8 0 4" />
                <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0 2">
                    <LineEdit Name="NewPasswordInput"
                              PlaceHolder="{Loc pipboy-hub-new-password-placeholder}"
                              HorizontalExpand="True"
                              StyleClasses="OpenRight" />
                    <Button Name="SetPasswordBtn"
                            Text="{Loc pipboy-hub-set-password}"
                            MinWidth="100"
                            StyleClasses="OpenLeft" />
                </BoxContainer>
                <Button Name="RemovePasswordBtn"
                        Text="{Loc pipboy-hub-remove-password}"
                        MinWidth="120"
                        Margin="0 4"
                        Visible="False" />
                <Button Name="LockBtn"
                        Text="{Loc pipboy-hub-lock}"
                        MinWidth="120"
                        Margin="0 2"
                        Visible="False" />
                <Label Name="PasswordStatusLabel"
                       Text=""
                       StyleClasses="LabelSubText"
                       Margin="0 2" />
            </BoxContainer>
        </PanelContainer>
    </BoxContainer>
</pipboy:PipBoySettingsUiFragment>
