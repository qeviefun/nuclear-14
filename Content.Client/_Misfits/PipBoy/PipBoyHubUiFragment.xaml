<pipboy:PipBoyHubUiFragment
    xmlns="https://spacestation14.io"
    xmlns:pipboy="clr-namespace:Content.Client._Misfits.PipBoy"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
    Orientation="Vertical"
    HorizontalExpand="True"
    VerticalExpand="True"
    Margin="5">

    <!-- ═══════════ LOCK SCREEN ═══════════ -->
    <BoxContainer Name="LockScreen"
                  Orientation="Vertical"
                  HorizontalExpand="True"
                  VerticalExpand="True"
                  Visible="False"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
        <Label Text="{Loc pipboy-hub-locked-title}"
               StyleClasses="LabelHeading"
               HorizontalAlignment="Center"
               Margin="0 8" />
        <LineEdit Name="PasswordInput"
                  PlaceHolder="{Loc pipboy-hub-password-placeholder}"
                  MinWidth="200"
                  Margin="0 4" />
        <Button Name="UnlockButton"
                Text="{Loc pipboy-hub-unlock}"
                MinWidth="120"
                HorizontalAlignment="Center"
                Margin="0 4" />
        <Label Name="LockErrorLabel"
               Text=""
               StyleClasses="LabelDanger"
               HorizontalAlignment="Center"
               Visible="False" />
    </BoxContainer>

    <!-- ═══════════ MAIN HUB (visible when unlocked) ═══════════ -->
    <BoxContainer Name="MainPanel"
                  Orientation="Vertical"
                  HorizontalExpand="True"
                  VerticalExpand="True">

        <!-- ── Header ── -->
        <controls:StripeBack MinSize="48 48" VerticalExpand="False">
            <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
                <Label Text="{Loc pipboy-hub-title}"
                       StyleClasses="LabelHeading"
                       HorizontalExpand="True"
                       Margin="8 0"
                       VerticalAlignment="Center" />
                <Label Name="OwnNumberLabel"
                       Text="#0000"
                       StyleClasses="LabelSubText"
                       VerticalAlignment="Center"
                       Margin="0 0 8 0" />
            </BoxContainer>
        </controls:StripeBack>

        <!-- ── Tab buttons ── -->
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0 4">
            <Button Name="TabContactsBtn"
                    Text="{Loc pipboy-hub-tab-contacts}"
                    HorizontalExpand="True"
                    StyleClasses="OpenBoth"
                    Margin="0 0 2 0" />
            <Button Name="TabGroupsBtn"
                    Text="{Loc pipboy-hub-tab-groups}"
                    HorizontalExpand="True"
                    StyleClasses="OpenBoth"
                    Margin="0 0 2 0" />
            <Button Name="TabDirectoryBtn"
                    Text="{Loc pipboy-hub-tab-directory}"
                    HorizontalExpand="True"
                    StyleClasses="OpenBoth"
                    Margin="0 0 2 0" />
            <Button Name="TabSettingsBtn"
                    Text="{Loc pipboy-hub-tab-settings}"
                    HorizontalExpand="True"
                    StyleClasses="OpenBoth" />
        </BoxContainer>

        <!-- ╔══════════════════════════════════════════╗ -->
        <!-- ║           CONTACTS TAB                   ║ -->
        <!-- ╚══════════════════════════════════════════╝ -->
        <BoxContainer Name="ContactsTab"
                      Orientation="Vertical"
                      HorizontalExpand="True"
                      VerticalExpand="True">

            <!-- SOS Beacon button -->
            <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0 2">
                <Button Name="SosBeaconBtn"
                        Text="{Loc pipboy-hub-sos-beacon}"
                        HorizontalExpand="True"
                        StyleClasses="Caution"
                        MinHeight="32" />
            </BoxContainer>

            <!-- SOS Alerts panel -->
            <PanelContainer Name="SosAlertsPanel"
                            StyleClasses="AngleRect"
                            MaxHeight="100"
                            Visible="False"
                            Margin="0 2">
                <BoxContainer Orientation="Vertical" Margin="4">
                    <Label Text="{Loc pipboy-hub-sos-alerts-header}"
                           StyleClasses="LabelHeading" />
                    <ScrollContainer MaxHeight="80" HScrollEnabled="False">
                        <BoxContainer Name="SosAlertsList"
                                      Orientation="Vertical" />
                    </ScrollContainer>
                </BoxContainer>
            </PanelContainer>

            <!-- Add contact row -->
            <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0 2">
                <LineEdit Name="ContactNumberInput"
                          PlaceHolder="{Loc pipboy-hub-contact-number-placeholder}"
                          HorizontalExpand="True"
                          StyleClasses="OpenRight" />
                <Button Name="ContactAddBtn"
                        Text="{Loc pipboy-hub-contact-add}"
                        MinWidth="60"
                        StyleClasses="OpenLeft" />
            </BoxContainer>

            <!-- Contact list -->
            <PanelContainer StyleClasses="AngleRect" VerticalExpand="True" HorizontalExpand="True">
                <ScrollContainer VerticalExpand="True" HorizontalExpand="True" HScrollEnabled="False">
                    <BoxContainer Name="ContactList"
                                  Orientation="Vertical"
                                  VerticalExpand="True"
                                  HorizontalExpand="True"
                                  Margin="4">
                        <Label Name="NoContactsLabel"
                               Text="{Loc pipboy-hub-no-contacts}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               StyleClasses="LabelSubText" />
                    </BoxContainer>
                </ScrollContainer>
            </PanelContainer>

            <!-- Contact locations readout -->
            <PanelContainer Name="ContactLocationsPanel"
                            StyleClasses="AngleRect"
                            MaxHeight="100"
                            Visible="False"
                            Margin="0 2 0 0">
                <BoxContainer Orientation="Vertical" Margin="4">
                    <Label Text="{Loc pipboy-hub-contact-locations-header}"
                           StyleClasses="LabelSubText" />
                    <BoxContainer Name="ContactLocationsList"
                                  Orientation="Vertical" />
                </BoxContainer>
            </PanelContainer>

            <!-- Quick message row -->
            <BoxContainer Name="ContactMessageRow"
                          Orientation="Horizontal"
                          HorizontalExpand="True"
                          Margin="0 2 0 0"
                          Visible="False">
                <Label Name="ContactMessageTarget"
                       Text=""
                       StyleClasses="LabelSubText"
                       VerticalAlignment="Center"
                       Margin="0 0 4 0" />
                <LineEdit Name="ContactMessageInput"
                          PlaceHolder="{Loc pipboy-hub-message-placeholder}"
                          HorizontalExpand="True"
                          StyleClasses="OpenRight" />
                <Button Name="ContactSendBtn"
                        Text="{Loc pipboy-hub-send}"
                        MinWidth="50"
                        StyleClasses="OpenLeft" />
            </BoxContainer>

            <!-- Contact note edit row -->
            <BoxContainer Name="ContactNoteRow"
                          Orientation="Horizontal"
                          HorizontalExpand="True"
                          Margin="0 2 0 0"
                          Visible="False">
                <Label Name="ContactNoteTarget"
                       Text=""
                       StyleClasses="LabelSubText"
                       VerticalAlignment="Center"
                       Margin="0 0 4 0" />
                <LineEdit Name="ContactNoteInput"
                          PlaceHolder="{Loc pipboy-hub-note-placeholder}"
                          HorizontalExpand="True"
                          StyleClasses="OpenRight" />
                <Button Name="ContactNoteSaveBtn"
                        Text="{Loc pipboy-hub-note-save}"
                        MinWidth="50"
                        StyleClasses="OpenLeft" />
            </BoxContainer>
        </BoxContainer>

        <!-- ╔══════════════════════════════════════════╗ -->
        <!-- ║             GROUPS TAB                   ║ -->
        <!-- ╚══════════════════════════════════════════╝ -->
        <BoxContainer Name="GroupsTab"
                      Orientation="Vertical"
                      HorizontalExpand="True"
                      VerticalExpand="True"
                      Visible="False">
            <!-- Create / join row -->
            <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0 2">
                <LineEdit Name="GroupNameInput"
                          PlaceHolder="{Loc pipboy-hub-group-name-placeholder}"
                          HorizontalExpand="True"
                          StyleClasses="OpenRight" />
                <Button Name="GroupCreateBtn"
                        Text="{Loc pipboy-hub-group-create}"
                        MinWidth="60"
                        StyleClasses="OpenLeft"
                        Margin="2 0 0 0" />
            </BoxContainer>
            <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0 2">
                <LineEdit Name="GroupIdInput"
                          PlaceHolder="{Loc pipboy-hub-group-id-placeholder}"
                          HorizontalExpand="True"
                          StyleClasses="OpenRight" />
                <LineEdit Name="GroupPasswordInput"
                          PlaceHolder="{Loc pipboy-hub-group-password-placeholder}"
                          MinWidth="100"
                          Margin="2 0 0 0" />
                <Button Name="GroupJoinBtn"
                        Text="{Loc pipboy-hub-group-join}"
                        MinWidth="60"
                        StyleClasses="OpenLeft"
                        Margin="2 0 0 0" />
            </BoxContainer>

            <!-- Split: group list on left, group chat/tracking on right -->
            <BoxContainer Orientation="Horizontal" VerticalExpand="True" HorizontalExpand="True" Margin="0 4 0 0">
                <!-- Group list -->
                <PanelContainer StyleClasses="AngleRect" VerticalExpand="True" MaxWidth="160">
                    <ScrollContainer VerticalExpand="True" MinWidth="150" HorizontalExpand="True" HScrollEnabled="False">
                        <BoxContainer Name="GroupList"
                                      Orientation="Vertical"
                                      VerticalExpand="True"
                                      HorizontalExpand="True"
                                      Margin="4">
                            <Label Name="NoGroupsLabel"
                                   Text="{Loc pipboy-hub-no-groups}"
                                   HorizontalAlignment="Center"
                                   StyleClasses="LabelSubText" />
                        </BoxContainer>
                    </ScrollContainer>
                </PanelContainer>

                <!-- Group chat/tracking panel -->
                <PanelContainer StyleClasses="AngleRect" VerticalExpand="True" HorizontalExpand="True" Margin="4 0 0 0">
                    <BoxContainer Orientation="Vertical" VerticalExpand="True" HorizontalExpand="True" Margin="4">
                        <Label Name="GroupChatTitle"
                               Text="{Loc pipboy-hub-group-select-prompt}"
                               StyleClasses="LabelHeading"
                               Margin="0 0 0 4" />

                        <!-- Group tracking locations -->
                        <PanelContainer Name="GroupTrackingPanel"
                                        StyleClasses="AngleRect"
                                        MaxHeight="80"
                                        Visible="False"
                                        Margin="0 0 0 2">
                            <BoxContainer Orientation="Vertical" Margin="4">
                                <Label Text="{Loc pipboy-hub-group-tracking-header}"
                                       StyleClasses="LabelSubText" />
                                <BoxContainer Name="GroupTrackingList"
                                              Orientation="Vertical" />
                            </BoxContainer>
                        </PanelContainer>

                        <!-- Group waypoints -->
                        <PanelContainer Name="GroupWaypointsPanel"
                                        StyleClasses="AngleRect"
                                        MaxHeight="100"
                                        Visible="False"
                                        Margin="0 0 0 2">
                            <BoxContainer Orientation="Vertical" Margin="4">
                                <Label Text="{Loc pipboy-hub-waypoints-header}"
                                       StyleClasses="LabelSubText" />
                                <BoxContainer Name="GroupWaypointsList"
                                              Orientation="Vertical" />
                                <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0 2 0 0">
                                    <LineEdit Name="WaypointLabelInput"
                                              PlaceHolder="{Loc pipboy-hub-waypoint-label-placeholder}"
                                              HorizontalExpand="True"
                                              StyleClasses="OpenRight" />
                                    <Button Name="WaypointAddBtn"
                                            Text="{Loc pipboy-hub-waypoint-add}"
                                            MinWidth="50"
                                            StyleClasses="OpenLeft" />
                                </BoxContainer>
                            </BoxContainer>
                        </PanelContainer>

                        <!-- Group password (for owner) -->
                        <BoxContainer Name="GroupEncryptionRow"
                                      Orientation="Horizontal"
                                      HorizontalExpand="True"
                                      Margin="0 0 0 2"
                                      Visible="False">
                            <LineEdit Name="GroupEncryptPasswordInput"
                                      PlaceHolder="{Loc pipboy-hub-group-set-password-placeholder}"
                                      HorizontalExpand="True"
                                      StyleClasses="OpenRight" />
                            <Button Name="GroupSetPasswordBtn"
                                    Text="{Loc pipboy-hub-group-set-password}"
                                    MinWidth="60"
                                    StyleClasses="OpenLeft" />
                        </BoxContainer>

                        <!-- Radio connection status -->
                        <Label Name="RadioStatusLabel"
                               Text=""
                               StyleClasses="LabelSubText"
                               Visible="False"
                               Margin="0 0 0 2" />

                        <!-- Group messages -->
                        <ScrollContainer Name="GroupMessagesScroll"
                                         VerticalExpand="True"
                                         HorizontalExpand="True"
                                         Visible="False">
                            <BoxContainer Name="GroupMessageList"
                                          Orientation="Vertical"
                                          VerticalExpand="True"
                                          HorizontalExpand="True" />
                        </ScrollContainer>

                        <!-- Group message input -->
                        <BoxContainer Name="GroupMessageInputRow"
                                      Orientation="Horizontal"
                                      HorizontalExpand="True"
                                      Margin="0 4 0 0"
                                      Visible="False">
                            <LineEdit Name="GroupMessageInput"
                                      PlaceHolder="{Loc pipboy-hub-message-placeholder}"
                                      HorizontalExpand="True"
                                      StyleClasses="OpenRight" />
                            <Button Name="GroupSendBtn"
                                    Text="{Loc pipboy-hub-send}"
                                    MinWidth="50"
                                    StyleClasses="OpenLeft" />
                        </BoxContainer>
                    </BoxContainer>
                </PanelContainer>
            </BoxContainer>
        </BoxContainer>

        <!-- ╔══════════════════════════════════════════╗ -->
        <!-- ║           DIRECTORY TAB                  ║ -->
        <!-- ╚══════════════════════════════════════════╝ -->
        <BoxContainer Name="DirectoryTab"
                      Orientation="Vertical"
                      HorizontalExpand="True"
                      VerticalExpand="True"
                      Visible="False">
            <Label Text="{Loc pipboy-hub-directory-header}"
                   StyleClasses="LabelSubText"
                   Margin="0 2" />

            <PanelContainer StyleClasses="AngleRect" VerticalExpand="True" HorizontalExpand="True">
                <ScrollContainer VerticalExpand="True" HorizontalExpand="True" HScrollEnabled="False">
                    <BoxContainer Name="DirectoryList"
                                  Orientation="Vertical"
                                  VerticalExpand="True"
                                  HorizontalExpand="True"
                                  Margin="4">
                        <Label Name="NoDirectoryLabel"
                               Text="{Loc pipboy-hub-no-directory}"
                               HorizontalAlignment="Center"
                               StyleClasses="LabelSubText" />
                    </BoxContainer>
                </ScrollContainer>
            </PanelContainer>

            <!-- Directory message row -->
            <BoxContainer Name="DirectoryMessageRow"
                          Orientation="Horizontal"
                          HorizontalExpand="True"
                          Margin="0 2 0 0"
                          Visible="False">
                <Label Name="DirectoryMessageTarget"
                       Text=""
                       StyleClasses="LabelSubText"
                       VerticalAlignment="Center"
                       Margin="0 0 4 0" />
                <LineEdit Name="DirectoryMessageInput"
                          PlaceHolder="{Loc pipboy-hub-message-placeholder}"
                          HorizontalExpand="True"
                          StyleClasses="OpenRight" />
                <Button Name="DirectorySendBtn"
                        Text="{Loc pipboy-hub-send}"
                        MinWidth="50"
                        StyleClasses="OpenLeft" />
            </BoxContainer>

            <!-- Dead Drop panel -->
            <PanelContainer Name="DeadDropPanel"
                            StyleClasses="AngleRect"
                            MaxHeight="140"
                            Margin="0 4 0 0">
                <BoxContainer Orientation="Vertical" Margin="4">
                    <Label Text="{Loc pipboy-hub-dead-drop-header}"
                           StyleClasses="LabelHeading" />

                    <!-- Nearby dead drops -->
                    <ScrollContainer MaxHeight="60" HScrollEnabled="False">
                        <BoxContainer Name="DeadDropList"
                                      Orientation="Vertical" />
                    </ScrollContainer>
                    <Label Name="NoDeadDropsLabel"
                           Text="{Loc pipboy-hub-no-dead-drops}"
                           StyleClasses="LabelSubText"
                           HorizontalAlignment="Center" />

                    <!-- Create dead drop -->
                    <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0 2 0 0">
                        <LineEdit Name="DeadDropContentInput"
                                  PlaceHolder="{Loc pipboy-hub-dead-drop-content-placeholder}"
                                  HorizontalExpand="True"
                                  StyleClasses="OpenRight" />
                        <LineEdit Name="DeadDropTargetInput"
                                  PlaceHolder="{Loc pipboy-hub-dead-drop-target-placeholder}"
                                  MinWidth="80"
                                  Margin="2 0 0 0" />
                        <Button Name="DeadDropCreateBtn"
                                Text="{Loc pipboy-hub-dead-drop-create}"
                                MinWidth="50"
                                StyleClasses="OpenLeft"
                                Margin="2 0 0 0" />
                    </BoxContainer>
                </BoxContainer>
            </PanelContainer>
        </BoxContainer>

        <!-- ╔══════════════════════════════════════════╗ -->
        <!-- ║           SETTINGS TAB                   ║ -->
        <!-- ╚══════════════════════════════════════════╝ -->
        <BoxContainer Name="SettingsTab"
                      Orientation="Vertical"
                      HorizontalExpand="True"
                      VerticalExpand="True"
                      Visible="False">
            <PanelContainer StyleClasses="AngleRect" HorizontalExpand="True" Margin="0 2">
                <BoxContainer Orientation="Vertical" Margin="8">
                    <!-- Visibility toggle -->
                    <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0 4">
                        <Label Text="{Loc pipboy-hub-settings-visibility}"
                               HorizontalExpand="True"
                               VerticalAlignment="Center" />
                        <Button Name="VisibilityToggleBtn"
                                Text="{Loc pipboy-hub-visible}"
                                MinWidth="80" />
                    </BoxContainer>

                    <!-- Status section -->
                    <Label Text="{Loc pipboy-hub-settings-status}"
                           StyleClasses="LabelHeading"
                           Margin="0 8 0 4" />
                    <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0 2">
                        <OptionButton Name="StatusDropdown"
                                      HorizontalExpand="False"
                                      MinWidth="120" />
                        <LineEdit Name="StatusMessageInput"
                                  PlaceHolder="{Loc pipboy-hub-status-message-placeholder}"
                                  HorizontalExpand="True"
                                  Margin="4 0 0 0"
                                  StyleClasses="OpenRight" />
                        <Button Name="SetStatusBtn"
                                Text="{Loc pipboy-hub-set-status}"
                                MinWidth="60"
                                StyleClasses="OpenLeft" />
                    </BoxContainer>
                    <Label Name="CurrentStatusLabel"
                           Text=""
                           StyleClasses="LabelSubText"
                           Margin="0 2" />

                    <!-- Password section -->
                    <Label Text="{Loc pipboy-hub-settings-password}"
                           StyleClasses="LabelHeading"
                           Margin="0 8 0 4" />
                    <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="0 2">
                        <LineEdit Name="NewPasswordInput"
                                  PlaceHolder="{Loc pipboy-hub-new-password-placeholder}"
                                  HorizontalExpand="True"
                                  StyleClasses="OpenRight" />
                        <Button Name="SetPasswordBtn"
                                Text="{Loc pipboy-hub-set-password}"
                                MinWidth="100"
                                StyleClasses="OpenLeft" />
                    </BoxContainer>
                    <Button Name="RemovePasswordBtn"
                            Text="{Loc pipboy-hub-remove-password}"
                            MinWidth="120"
                            Margin="0 4"
                            Visible="False" />
                    <Button Name="LockBtn"
                            Text="{Loc pipboy-hub-lock}"
                            MinWidth="120"
                            Margin="0 2"
                            Visible="False" />
                    <Label Name="PasswordStatusLabel"
                           Text=""
                           StyleClasses="LabelSubText"
                           Margin="0 2" />
                </BoxContainer>
            </PanelContainer>
        </BoxContainer>
    </BoxContainer>
</pipboy:PipBoyHubUiFragment>
