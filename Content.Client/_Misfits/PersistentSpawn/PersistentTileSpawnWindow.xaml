<!-- #Misfits Add - Persistent Tile Spawn Window.
     Mirrors the standard Tile Spawn Panel but tiles placed through this
     panel are saved to JSON and re-placed automatically on round restart. -->
<DefaultWindow
    xmlns="https://spacestation14.io"
    Title="{Loc misfits-persistent-tile-spawn-window-title}"
    SetSize="350 350"
    MinSize="300 200">
    <BoxContainer Orientation="Vertical">
        <Label Text="{Loc misfits-persistent-tile-spawn-window-notice}" StyleClasses="LabelSubText" Margin="0 0 0 4" />
        <BoxContainer Orientation="Horizontal">
            <LineEdit Name="SearchBar" Access="Public" HorizontalExpand="True" PlaceHolder="{Loc window-search-bar-placeholder}"/>
            <Button Name="ClearButton" Access="Public" Text="{Loc window-clear-button}"/>
        </BoxContainer>
        <ItemList Name="TileList" Access="Public" VerticalExpand="True"/>
        <!-- #Misfits Add - Erase button mirrors the vanilla TileSpawnWindow erase + mirrored layout -->
        <BoxContainer Orientation="Horizontal">
            <Button Name="MirroredButton" Access="Public" ToggleMode="True" Text="{Loc tile-spawn-window-mirror-button-text}"/>
            <Button Name="EraseButton" Access="Public" ToggleMode="True" Text="{Loc window-erase-button-text}"/>
        </BoxContainer>
        <Label Name="RotationLabel" Access="Public"/>
    </BoxContainer>
</DefaultWindow>
