# Scoping system locale strings — directional scope popups and error messages

# Popup shown to user when scoping in
n14-action-popup-scoping-user = You look through {THE($scope)}.

# Popup shown to user when unscoping
n14-action-popup-scoping-stopping-user = You stop looking through {THE($scope)}.

# Popup when cycling zoom levels
n14-action-popup-scope-cycle-zoom = Zoom set to {$zoom}.

# Error: scope attachment must be attached to a gun
n14-action-popup-scoping-must-attach = {THE($scope)} must be attached to a weapon first.

# Error: must hold the scoped item in active hand
n14-action-popup-scoping-user-must-hold = You need to hold {THE($scope)} in your active hand.

# Error: cannot scope while being pulled
n14-action-popup-scoping-user-must-not-pulled = You can't look through {THE($scope)} while being pulled.

# Error: cannot scope while in a container
n14-action-popup-scoping-user-must-not-contained = You can't look through {THE($scope)} right now.

# Error: weapon must be wielded to scope
n14-action-popup-scoping-user-must-wield = You need to wield {THE($scope)} first.

# Action names
n14-action-toggle-scope = Toggle Scope
n14-action-toggle-scope-description = Look through the scope to shift your view in the direction you're facing.

n14-action-cycle-zoom = Cycle Zoom
n14-action-cycle-zoom-description = Cycle through available zoom levels on the scope.
