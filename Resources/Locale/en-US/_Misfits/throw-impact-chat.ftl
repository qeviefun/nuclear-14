# #Misfits Add: Emote strings for ThrowImpactChatSystem - broadcast when a thrown item hits a mob.

misfits-chat-throw-hit = throws { $item } at { $target }!
misfits-chat-throw-hit-victim = was hit by { $user }'s { $item }!

misfits-chat-throw-poison-hit = hurls { $item } at { $target }!
misfits-chat-throw-poison-hit-victim = was struck by { $user }'s { $item }!
