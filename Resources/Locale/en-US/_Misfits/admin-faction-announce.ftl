# Misfits Add — localization strings for faction-targeted admin announcements.
# These appear in the Admin → Announce dropdown and pre-fill the sender field
# with the canonical in-universe authority figure for each faction.

## Dropdown labels
admin-announce-type-faction-legion  = Legion (Legate)
admin-announce-type-faction-ncr     = NCR (Captain)
admin-announce-type-faction-bos     = BoS (Elder)
admin-announce-type-faction-enclave = Enclave (Director)

## Default sender names pre-filled into the Announcer field
admin-announce-faction-sender-legion  = Legate
admin-announce-faction-sender-ncr     = NCR Captain
admin-announce-faction-sender-bos     = Elder
admin-announce-faction-sender-enclave = Director
