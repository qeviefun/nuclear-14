# #Misfits Add: Localization for blueprint faction-restricted lathe recipes.

# Shown as a popup when a player tries to queue a blueprint recipe they don't
# have faction access to (AvailableFaction whitelist check fails).
lathe-blueprint-faction-denied = You lack the necessary faction training to produce this blueprint.
lathe-blueprint-insufficient-materials = Not enough materials for this blueprint recipe.
lathe-blueprint-queue-failed = This blueprint recipe cannot be queued right now.

