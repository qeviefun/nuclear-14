# #Misfits Add: Emote strings for BuckleChatSystem - broadcast when one player straps or unstraps another.

misfits-chat-buckle-strap = straps { $target } into { $strap }.
misfits-chat-buckle-victim = is strapped into { $strap } by { $user }.

misfits-chat-unbuckle-release = releases { $target } from { $strap }.
misfits-chat-unbuckle-victim = is released from { $strap } by { $user }.
